# claude-stack Konfiguration
#
# Diese Datei nach `stack.conf` kopieren und anpassen.
# `stack.conf` ist gitignored — Pfade und Passwörter bleiben lokal.

# === Generelle Settings ===

# Wo liegen deine Projektordner? Globbing wird unterstützt.
# Default: alle Ordner mit Underscore-Prefix im Home-Verzeichnis.
PROJECTS_GLOB="$HOME/_*"

# Code-Server Bind-Adresse und Port. 0.0.0.0 macht ihn auf allen Interfaces
# erreichbar — der Mac mini wird dann von jedem Gerät im Heimnetz (oder via
# VPN) unter http://<mac-mini-ip>:8443 ansprechbar.
CODESERVER_BIND="0.0.0.0:8443"

# Code-Server Passwort (für Browser-Login).
# UNBEDINGT ÄNDERN. Generiere ein zufälliges, z.B. mit:
#   openssl rand -base64 24
CODESERVER_PASSWORD="CHANGE_ME"

# Dashboard-Port
DASHBOARD_PORT="8390"

# Logs landen hier (wird automatisch angelegt)
LOG_DIR="$HOME/Library/Logs/claude-stack"

# === Claude-spezifisch ===

# Soll `claude --continue` beim Auto-Start verwendet werden?
# true  = nahtlos weitermachen wo du aufgehört hast (empfohlen)
# false = jedes Mal frische Session
CLAUDE_CONTINUE="true"

# Zusätzliche Flags für Claude. Nützlich z.B. für --dangerously-skip-permissions
# wenn du Auto-Approve willst (Vorsicht — kann auf prod-Systemen gefährlich sein!).
# CLAUDE_EXTRA_FLAGS="--dangerously-skip-permissions"
CLAUDE_EXTRA_FLAGS=""

# === Pfade — anpassen falls dein Brew nicht in /opt/homebrew/bin liegt ===
# (Apple Silicon: /opt/homebrew, Intel: /usr/local)
BREW_PREFIX="/opt/homebrew"

# === Optional: explizite Projektliste ===
# Wenn du nicht alle Ordner aus PROJECTS_GLOB nutzen willst, kannst du
# hier eine explizite Liste setzen (überschreibt PROJECTS_GLOB).
# Format: ein Pfad pro Zeile in der EXPLICIT_PROJECTS-Variable.
#
# EXPLICIT_PROJECTS=(
#   "$HOME/_project1"
#   "$HOME/work/important-repo"
# )
