# Optional ~/.tmux.conf additions (or use as-is if you have none).
#
# These settings make NEW tmux windows and panes — the ones you create with
# Ctrl+b c or Ctrl+b " inside a running session — start as login shells too,
# so Oh My Zsh, your theme, aliases etc. are also available there.
#
# Copy this file to ~/.tmux.conf (or append it to an existing one), then run
#   tmux kill-server && launchctl kickstart -k gui/$(id -u)/com.user.claude-stack.<name>
# to restart sessions with the new config.

# zsh as the default shell for new panes/windows, started as a login shell.
set -g default-command "/bin/zsh -l"
set -g default-shell "/bin/zsh"

# Quality-of-life — drop anything you don't want.

# True-color support (matters for many zsh themes).
set -g default-terminal "screen-256color"
set -ga terminal-overrides ",*256col*:Tc"

# Mouse support (scroll, drag-resize panes).
set -g mouse on

# Toggle mouse mode with Ctrl+b m.
# In code-server (xterm.js in the browser), tmux's mouse-on captures drag
# selections so the browser can't copy text. Press Ctrl+b m to flip mouse
# off, select+copy with the browser's native selection, then Ctrl+b m again.
bind m set -g mouse \; display "mouse: #{?mouse,on,off}"

# Clipboard via OSC 52 — works for code-server in the browser:
# tmux sends selected text as an escape sequence to xterm.js, which writes it
# to the *browser's* clipboard (i.e. your local machine), not pbcopy on the
# Mac mini. Without this, mouse-drag selections vanish on release because
# tmux captures the drag but has nowhere to put the text.
set -g set-clipboard on
set -ga terminal-overrides ',*:Ms=\E]52;%p1%s;%p2%s\7'
set -as terminal-features ',*:clipboard'

# Mouse-drag selection → buffer (set-clipboard on then emits OSC 52).
bind -T copy-mode    MouseDragEnd1Pane send -X copy-selection-no-clear
bind -T copy-mode-vi MouseDragEnd1Pane send -X copy-selection-no-clear

# Disable tmux's right-click pane menu so only VSCode's terminal menu shows.
unbind -n MouseDown3Pane
unbind -n MouseDown3Status
unbind -n MouseDown3StatusLeft

# Larger scrollback buffer.
set -g history-limit 50000

# Window/pane indices start at 1 instead of 0 (closer to the keyboard).
set -g base-index 1
setw -g pane-base-index 1
