# clawdstacc configuration
#
# Copy this file to `clawdstacc.conf` and edit it.
# `clawdstacc.conf` is gitignored — paths and passwords stay local.

# === General settings ===

# Where do your project folders live? Globbing is supported.
# Default: every folder in $HOME with a leading underscore.
PROJECTS_GLOB="$HOME/_*"

# code-server bind address and port. 0.0.0.0 makes it reachable on every
# interface — the host is then available from any device on your home network
# (or via VPN) at http://<host>:8443.
CODESERVER_BIND="0.0.0.0:8443"

# Public URL for code-server when accessed through a reverse proxy / tunnel
# (Cloudflare Tunnel, Tailscale Funnel, etc.). When set AND the dashboard is
# being accessed via HTTPS, the "code-server ↗" links redirect here instead of
# to <host>:<port>. Leave empty for LAN-only setups.
# CODESERVER_PUBLIC_URL="https://code.kghf.io"

# code-server auth mode: "password" or "none".
# Set to "none" if you protect code-server with a reverse proxy / Cloudflare
# Access in front (avoids the second login prompt). Set to "password" for
# LAN-only setups without an upstream auth layer.
CODESERVER_AUTH="password"

# code-server password — only used when CODESERVER_AUTH=password.
# Generate: openssl rand -base64 24
CODESERVER_PASSWORD="CHANGE_ME"

# Dashboard port
DASHBOARD_PORT="8390"

# Logs land here (created automatically).
LOG_DIR="$HOME/Library/Logs/clawdstacc"

# === Claude-specific ===

# Use `claude --continue` on auto-start?
# true  = pick up where you left off (recommended)
# false = always start a fresh session
CLAUDE_CONTINUE="true"

# Extra flags passed to claude. Useful e.g. for --dangerously-skip-permissions
# if you want auto-approve (be careful — risky on production systems).
# CLAUDE_EXTRA_FLAGS="--dangerously-skip-permissions"
CLAUDE_EXTRA_FLAGS=""

# === Paths — adjust if Homebrew is not in /opt/homebrew ===
# (Apple Silicon: /opt/homebrew, Intel: /usr/local)
BREW_PREFIX="/opt/homebrew"

# === Optional: explicit project list ===
# Overrides PROJECTS_GLOB. One path per line.
# Comment this out to fall back to the glob above.
#
# EXPLICIT_PROJECTS=(
#   "$HOME/_project1"
#   "$HOME/work/important-repo"
# )
